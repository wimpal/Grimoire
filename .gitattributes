# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly declare common text files
*.rs      text eol=lf
*.toml    text eol=lf
*.json    text eol=lf
*.js      text eol=lf
*.ts      text eol=lf
*.svelte  text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.sql     text eol=lf
*.lock    text eol=lf

# Binary files — no line ending conversion
*.png     binary
*.jpg     binary
*.ico     binary
*.svg     binary
